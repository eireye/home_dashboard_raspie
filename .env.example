# iCloud Calendar credentials
ICLOUD_EMAIL=your_email@example.com
ICLOUD_PASSWORD=your_app_specific_password_here

# Google Sheets for meal planning
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Weather location (optional - defaults to Oslo)
WEATHER_LAT=59.91
WEATHER_LON=10.75

# Transport stops (Entur/Ruter) - find IDs at https://stoppested.entur.org/
# Format: stop_id=name,stop_id=name
# Default: Sinsen T-bane
TRANSPORT_STOPS=NSR:StopPlace:61268=Sinsen T
